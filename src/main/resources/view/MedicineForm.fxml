<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="780.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.icet.controller.MedicineController">
    <children>
        <Label layoutX="40.0" layoutY="30.0" text="Manage Medicines" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>

        <TextField fx:id="txtCode" layoutX="40.0" layoutY="90.0" prefHeight="35.0" prefWidth="150.0" promptText="Medicine Code" />
        <TextField fx:id="txtName" layoutX="210.0" layoutY="90.0" prefHeight="35.0" prefWidth="250.0" promptText="Medicine Name" />
        <TextField fx:id="txtBrand" layoutX="480.0" layoutY="90.0" prefHeight="35.0" prefWidth="260.0" promptText="Brand" />

        <TextField fx:id="txtSupplierId" layoutX="40.0" layoutY="140.0" prefHeight="35.0" prefWidth="150.0" promptText="Supplier ID (e.g. S001)" />
        <DatePicker fx:id="dateExpiry" layoutX="210.0" layoutY="140.0" prefHeight="35.0" prefWidth="170.0" promptText="Expiry Date" />
        <TextField fx:id="txtQty" layoutX="400.0" layoutY="140.0" prefHeight="35.0" prefWidth="150.0" promptText="Qty on Hand" />
        <TextField fx:id="txtPrice" layoutX="570.0" layoutY="140.0" prefHeight="35.0" prefWidth="170.0" promptText="Unit Price (Rs)" />

        <Button layoutX="400.0" layoutY="200.0" mnemonicParsing="false" onAction="#btnSaveOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #2ecc71;" text="Save" textFill="WHITE">
            <font><Font name="System Bold" size="14.0" /></font>
        </Button>
        <Button layoutX="490.0" layoutY="200.0" mnemonicParsing="false" onAction="#btnUpdateOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #f39c12;" text="Update" textFill="WHITE">
            <font><Font name="System Bold" size="14.0" /></font>
        </Button>
        <Button layoutX="580.0" layoutY="200.0" mnemonicParsing="false" onAction="#btnDeleteOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #e74c3c;" text="Delete" textFill="WHITE">
            <font><Font name="System Bold" size="14.0" /></font>
        </Button>
        <Button layoutX="670.0" layoutY="200.0" mnemonicParsing="false" onAction="#btnClearOnAction" prefHeight="35.0" prefWidth="70.0" style="-fx-background-color: #95a5a6;" text="Clear" textFill="WHITE">
            <font><Font name="System Bold" size="14.0" /></font>
        </Button>

        <TableView fx:id="tblMedicines" layoutX="40.0" layoutY="260.0" prefHeight="350.0" prefWidth="700.0">
            <columns>
                <TableColumn fx:id="colCode" prefWidth="75.0" text="Code" />
                <TableColumn fx:id="colName" prefWidth="175.0" text="Name" />
                <TableColumn fx:id="colBrand" prefWidth="120.0" text="Brand" />
                <TableColumn fx:id="colSupplier" prefWidth="80.0" text="Supplier" />
                <TableColumn fx:id="colExpiry" prefWidth="90.0" text="Expiry" />
                <TableColumn fx:id="colQty" prefWidth="70.0" text="Qty" />
                <TableColumn fx:id="colPrice" prefWidth="88.0" text="Price" />
            </columns>
        </TableView>
    </children>
</AnchorPane>