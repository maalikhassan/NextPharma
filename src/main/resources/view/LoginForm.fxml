<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="400.0" style="-fx-background-color: #2c3e50;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.icet.controller.LoginController">
    <children>
        <Label layoutX="105.0" layoutY="60.0" text="💊 NextPharma" textFill="WHITE">
            <font><Font name="System Bold" size="26.0" /></font>
        </Label>
        <Label layoutX="145.0" layoutY="100.0" text="Secure Login" textFill="#bdc3c7">
            <font><Font size="18.0" /></font>
        </Label>

        <TextField fx:id="txtUsername" layoutX="50.0" layoutY="180.0" prefHeight="45.0" prefWidth="300.0" promptText="Username" style="-fx-background-radius: 5;" />
        <PasswordField fx:id="txtPassword" layoutX="50.0" layoutY="250.0" prefHeight="45.0" prefWidth="300.0" promptText="Password" style="-fx-background-radius: 5;" />

        <Button layoutX="50.0" layoutY="340.0" mnemonicParsing="false" onAction="#btnLoginOnAction" prefHeight="45.0" prefWidth="300.0" style="-fx-background-color: #2ecc71; -fx-background-radius: 5;" text="LOGIN" textFill="WHITE">
            <font><Font name="System Bold" size="18.0" /></font>
        </Button>
    </children>
</AnchorPane>