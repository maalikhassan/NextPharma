<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="780.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.icet.controller.HomeController">
    <children>
        <Label layoutX="40.0" layoutY="30.0" text="Dashboard Overview" textFill="#2c3e50">
            <font><Font name="System Bold" size="28.0" /></font>
        </Label>

        <Label layoutX="40.0" layoutY="90.0" text="Low Stock Alerts (Qty &lt; 20)" textFill="#e74c3c">
            <font><Font name="System Bold" size="18.0" /></font>
        </Label>
        <TableView fx:id="tblLowStock" layoutX="40.0" layoutY="125.0" prefHeight="200.0" prefWidth="700.0">
            <columns>
                <TableColumn fx:id="colLowCode" prefWidth="120.0" text="Item Code" />
                <TableColumn fx:id="colLowName" prefWidth="430.0" text="Medicine Name" />
                <TableColumn fx:id="colLowQty" prefWidth="148.0" text="Qty On Hand" />
            </columns>
        </TableView>

        <Label layoutX="40.0" layoutY="350.0" text="Expiring Soon (Within 30 Days)" textFill="#f39c12">
            <font><Font name="System Bold" size="18.0" /></font>
        </Label>
        <TableView fx:id="tblExpiring" layoutX="40.0" layoutY="385.0" prefHeight="220.0" prefWidth="700.0">
            <columns>
                <TableColumn fx:id="colExpCode" prefWidth="120.0" text="Item Code" />
                <TableColumn fx:id="colExpName" prefWidth="430.0" text="Medicine Name" />
                <TableColumn fx:id="colExpDate" prefWidth="148.0" text="Expiry Date" />
            </columns>
        </TableView>
    </children>
</AnchorPane>