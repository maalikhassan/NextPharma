<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="780.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.icet.controller.ReportsController">
    <children>
        <Label layoutX="40.0" layoutY="30.0" text="Generate Detailed Reports" textFill="#2c3e50">
            <font><Font name="System Bold" size="28.0" /></font>
        </Label>

        <VBox alignment="CENTER" layoutX="40.0" layoutY="120.0" prefWidth="700.0" spacing="25.0">
            <children>
                <Button mnemonicParsing="false" onAction="#btnPrintInventoryOnAction" prefHeight="60.0" prefWidth="700.0" style="-fx-background-color: #3498db; -fx-background-radius: 8;" text="📄 Full Inventory Summary Report" textFill="WHITE">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Button>
                <Button mnemonicParsing="false" onAction="#btnPrintSalesReportOnAction" prefHeight="60.0" prefWidth="700.0" style="-fx-background-color: #2ecc71; -fx-background-radius: 8;" text="📊 All-Time Sales &amp; Revenue Report" textFill="WHITE">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Button>
                <Button mnemonicParsing="false" onAction="#btnPrintSuppliersOnAction" prefHeight="60.0" prefWidth="700.0" style="-fx-background-color: #f39c12; -fx-background-radius: 8;" text="🤝 Supplier Contact Directory" textFill="WHITE">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Button>
            </children>
        </VBox>
    </children>
</AnchorPane>