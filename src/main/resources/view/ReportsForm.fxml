<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="780.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.icet.controller.ReportsController">
    <children>
        <Label layoutX="40.0" layoutY="30.0" text="Reports &amp; Analytics" textFill="#2c3e50">
            <font><Font name="System Bold" size="28.0" /></font>
        </Label>

        <HBox layoutX="40.0" layoutY="100.0" spacing="20.0">
            <children>
                <VBox alignment="CENTER" prefHeight="120.0" prefWidth="220.0" style="-fx-background-color: #3498db; -fx-background-radius: 10;">
                    <children>
                        <Label text="Total Medicines" textFill="WHITE"><font><Font name="System Bold" size="16.0" /></font></Label>
                        <Label fx:id="lblTotalMedicines" text="0" textFill="WHITE"><font><Font name="System Bold" size="36.0" /></font></Label>
                    </children>
                </VBox>
                <VBox alignment="CENTER" prefHeight="120.0" prefWidth="220.0" style="-fx-background-color: #2ecc71; -fx-background-radius: 10;">
                    <children>
                        <Label text="Total Sales (Rs.)" textFill="WHITE"><font><Font name="System Bold" size="16.0" /></font></Label>
                        <Label fx:id="lblTotalSales" text="0.00" textFill="WHITE"><font><Font name="System Bold" size="28.0" /></font></Label>
                    </children>
                </VBox>
                <VBox alignment="CENTER" prefHeight="120.0" prefWidth="220.0" style="-fx-background-color: #f39c12; -fx-background-radius: 10;">
                    <children>
                        <Label text="Active Suppliers" textFill="WHITE"><font><Font name="System Bold" size="16.0" /></font></Label>
                        <Label fx:id="lblTotalSuppliers" text="0" textFill="WHITE"><font><Font name="System Bold" size="36.0" /></font></Label>
                    </children>
                </VBox>
            </children>
        </HBox>

        <Label layoutX="40.0" layoutY="270.0" text="Generate Detailed Reports" textFill="#2c3e50">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>

        <VBox layoutX="40.0" layoutY="310.0" spacing="15.0">
            <children>
                <Button mnemonicParsing="false" onAction="#btnPrintInventoryOnAction" prefHeight="50.0" prefWidth="350.0" style="-fx-background-color: #34495e;" text="📄 Full Inventory Summary Report" textFill="WHITE">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
                <Button mnemonicParsing="false" onAction="#btnPrintSalesReportOnAction" prefHeight="50.0" prefWidth="350.0" style="-fx-background-color: #34495e;" text="📊 All-Time Sales &amp; Revenue Report" textFill="WHITE">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
                <Button mnemonicParsing="false" onAction="#btnPrintSuppliersOnAction" prefHeight="50.0" prefWidth="350.0" style="-fx-background-color: #34495e;" text="🤝 Supplier Contact Directory" textFill="WHITE">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
            </children>
        </VBox>
    </children>
</AnchorPane>