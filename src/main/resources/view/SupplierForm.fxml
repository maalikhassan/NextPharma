<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="780.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.icet.controller.SupplierController">
    <children>
        <Label layoutX="40.0" layoutY="30.0" text="Manage Suppliers" textFill="#2c3e50">
            <font><Font name="System Bold" size="28.0" /></font>
        </Label>

        <TextField fx:id="txtId" layoutX="40.0" layoutY="90.0" prefHeight="35.0" prefWidth="200.0" promptText="Supplier ID (e.g. S001)" />
        <TextField fx:id="txtName" layoutX="260.0" layoutY="90.0" prefHeight="35.0" prefWidth="250.0" promptText="Supplier Name" />
        <TextField fx:id="txtContact" layoutX="530.0" layoutY="90.0" prefHeight="35.0" prefWidth="210.0" promptText="Contact Number" />

        <TextField fx:id="txtSearch" layoutX="40.0" layoutY="150.0" prefHeight="35.0" prefWidth="300.0" promptText="Search by ID or Name..." style="-fx-border-color: #3498db; -fx-border-radius: 5;" />

        <Button layoutX="400.0" layoutY="150.0" mnemonicParsing="false" onAction="#btnSaveOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #2ecc71;" text="Save" textFill="WHITE">
            <font><Font name="System Bold" size="14.0" /></font>
        </Button>
        <Button layoutX="490.0" layoutY="150.0" mnemonicParsing="false" onAction="#btnUpdateOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #f39c12;" text="Update" textFill="WHITE">
            <font><Font name="System Bold" size="14.0" /></font>
        </Button>
        <Button layoutX="580.0" layoutY="150.0" mnemonicParsing="false" onAction="#btnDeleteOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #e74c3c;" text="Delete" textFill="WHITE">
            <font><Font name="System Bold" size="14.0" /></font>
        </Button>
        <Button layoutX="670.0" layoutY="150.0" mnemonicParsing="false" onAction="#btnClearOnAction" prefHeight="35.0" prefWidth="70.0" style="-fx-background-color: #95a5a6;" text="Clear" textFill="WHITE">
            <font><Font name="System Bold" size="14.0" /></font>
        </Button>

        <TableView fx:id="tblSuppliers" layoutX="40.0" layoutY="210.0" prefHeight="400.0" prefWidth="700.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="150.0" text="Supplier ID" />
                <TableColumn fx:id="colName" prefWidth="350.0" text="Supplier Name" />
                <TableColumn fx:id="colContact" prefWidth="198.0" text="Contact Number" />
            </columns>
        </TableView>
    </children>
</AnchorPane>