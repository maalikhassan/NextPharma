<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="780.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.icet.controller.BillingController">
    <children>
        <Label layoutX="40.0" layoutY="30.0" text="Point of Sale (POS)" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>

        <Label layoutX="40.0" layoutY="80.0" text="Order ID:">
            <font><Font size="14.0" /></font>
        </Label>
        <Label fx:id="lblOrderId" layoutX="110.0" layoutY="80.0" text="ORD-003" textFill="#c0392b">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>

        <ComboBox fx:id="cmbMedicineCode" layoutX="40.0" layoutY="120.0" prefHeight="35.0" prefWidth="150.0" promptText="Select Medicine" />
        <TextField fx:id="txtMedicineName" editable="false" layoutX="210.0" layoutY="120.0" prefHeight="35.0" prefWidth="200.0" promptText="Medicine Name" />
        <TextField fx:id="txtUnitPrice" editable="false" layoutX="430.0" layoutY="120.0" prefHeight="35.0" prefWidth="100.0" promptText="Unit Price" />
        <TextField fx:id="txtQtyOnHand" editable="false" layoutX="550.0" layoutY="120.0" prefHeight="35.0" prefWidth="90.0" promptText="Stock" />

        <TextField fx:id="txtBuyingQty" layoutX="40.0" layoutY="170.0" prefHeight="35.0" prefWidth="150.0" promptText="Enter Qty" />
        <Button layoutX="210.0" layoutY="170.0" mnemonicParsing="false" onAction="#btnAddToCartOnAction" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #3498db;" text="Add to Cart" textFill="WHITE">
            <font><Font name="System Bold" size="14.0" /></font>
        </Button>

        <TableView fx:id="tblCart" layoutX="40.0" layoutY="230.0" prefHeight="280.0" prefWidth="700.0">
            <columns>
                <TableColumn fx:id="colCode" prefWidth="100.0" text="Item Code" />
                <TableColumn fx:id="colName" prefWidth="250.0" text="Medicine Name" />
                <TableColumn fx:id="colUnitPrice" prefWidth="100.0" text="Unit Price" />
                <TableColumn fx:id="colQty" prefWidth="100.0" text="Quantity" />
                <TableColumn fx:id="colTotal" prefWidth="145.0" text="Total" />
            </columns>
        </TableView>

        <Label layoutX="40.0" layoutY="540.0" text="Net Total: Rs." textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <Label fx:id="lblNetTotal" layoutX="200.0" layoutY="540.0" text="0.00" textFill="#c0392b">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <Button layoutX="540.0" layoutY="535.0" mnemonicParsing="false" onAction="#btnPlaceOrderOnAction" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #2ecc71;" text="Place Order &amp; Print" textFill="WHITE">
            <font><Font name="System Bold" size="16.0" /></font>
        </Button>
    </children>
</AnchorPane>